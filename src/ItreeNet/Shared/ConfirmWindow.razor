@if (IsVisible)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999">
        <MudPaper Class="pa-6" Style="width:420px;max-width:90vw;">
            <MudText Typo="Typo.h6" Class="mb-3">@_title</MudText>
            <MudText Class="mb-4">@_content</MudText>
            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="@(() => CheckHandler.InvokeAsync(false))">Nein</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Check"
                           OnClick="@(() => CheckHandler.InvokeAsync(true))">Ja</MudButton>
            </MudStack>
        </MudPaper>
    </MudOverlay>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> CheckHandler { get; set; }
    [Parameter] public EnumConfirmType Type { get; set; }

    private string _title = string.Empty;
    private string _content = string.Empty;

    protected override void OnInitialized()
    {
        if (Type == EnumConfirmType.Cancel)
        {
            _title = "Abbrechen";
            _content = "Wollen Sie Ihre Änderungen wirklich verwerfen?";
        }
        else if (Type == EnumConfirmType.Delete)
        {
            _title = "Löschen";
            _content = "Wollen Sie das Objekt wirklich löschen?";
        }
        else if (Type == EnumConfirmType.Create)
        {
            _title = "Erstellen";
            _content = "Wollen Sie das Objekt wirklich erstellen?";
        }
    }

    protected override void OnParametersSet()
    {
        StateHasChanged();
        base.OnParametersSet();
    }
}
