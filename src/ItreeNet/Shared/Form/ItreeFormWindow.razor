@using FluentValidation
@inject IJSRuntime Js
@typeparam TModel

@if (WindowVisible && Model != null)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="1300">
        <MudPaper Class="pa-0" Style="@($"width:{WindowWidth};max-width:95vw;max-height:90vh;overflow-y:auto;border-top:4px solid {_accentColor};")">
            <MudToolBar Dense="true" Class="mud-theme-primary px-4">
                <MudText Typo="Typo.h6">@_windowTitle</MudText>
            </MudToolBar>
            <div class="pa-4">
                <ItreeForm Model="@Model"
                           OnSave="@OnSave"
                           OnClose="@OnClose"
                           Validator="@Validator"
                           AutoGenerate="@AutoGenerate"
                           WithBaseProperties="@WithBaseProperties"
                           IgnorePropertyList="@IgnorePropertyList"
                           Writeable="@Writeable"
                           DropdownList="@DropdownList"
                           CustomTypes="@CustomTypes"
                           IgnorePropertyCheckingList="@IgnorePropertyCheckingList"
                           CustomHasChanges="@CustomHasChanges"
                           CustomHasChangesChanged="@CustomHasChangesChanged"
                           ExcludeFormButtons="@ExcludeFormButtons"
                           ValidationStrictMode="@ValidationStrictMode">
                    <ChildContent>@ChildContent</ChildContent>
                </ItreeForm>
            </div>
        </MudPaper>
    </MudOverlay>
}

@code {
    [Parameter] public bool WindowVisible { get; set; }
    [Parameter] public string WindowWidth { get; set; } = "800px";
    [Parameter] public TModel? Model { get; set; }
    [Parameter] public IValidator? Validator { get; set; }
    [Parameter] public EventCallback<EditContext> OnSave { get; set; }
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool AutoGenerate { get; set; }
    [Parameter] public bool WithBaseProperties { get; set; }
    [Parameter] public string? IgnorePropertyList { get; set; }
    [Parameter] public bool Writeable { get; set; }
    [Parameter] public List<ItreeFormDropdown>? DropdownList { get; set; }
    [Parameter] public List<ItreeFormPropertyType>? CustomTypes { get; set; }
    [Parameter] public string? IgnorePropertyCheckingList { get; set; }
    [Parameter] public bool? CustomHasChanges { get; set; }
    [Parameter] public EventCallback CustomHasChangesChanged { get; set; }
    [Parameter] public bool ExcludeFormButtons { get; set; }
    [Parameter] public bool ValidationStrictMode { get; set; } = true;
    [Parameter] public EnumSettingCategory? Category { get; set; }

    private Guid _objectId = Guid.Empty;
    private string _accentColor = "#000000";
    private string _windowTitle = string.Empty;

    protected override void OnParametersSet()
    {
        _accentColor = Category switch
        {
            EnumSettingCategory.Allgemein => "#f6c23e",
            EnumSettingCategory.Zeiterfassung => "#4e73df",
            EnumSettingCategory.Taskboard => "#1cc88a",
            _ => "#000000"
        };

        if (Model != null)
        {
            var guidString = Model.GetType().GetProperty("Id")?.GetValue(Model, null)?.ToString();
            var isBool = Guid.TryParse(guidString, out var guid);
            if (!isBool) throw new InvalidOperationException("ItreeForm there is no Guid on Model");
            _objectId = guid;

            _windowTitle = _objectId == Guid.Empty
                ? $"{Model.GetType().Name} hinzufügen"
                : Writeable ? $"{Model.GetType().Name} bearbeiten" : $"{Model.GetType().Name} anzeigen";
        }

        StateHasChanged();
    }
}
