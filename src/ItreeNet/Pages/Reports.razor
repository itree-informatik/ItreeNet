@page "/intern/reports"
@attribute [Authorize(Policy = "internPolicy")]
@using MitarbeiterModel = ItreeNet.Data.Models.Mitarbeiter
@inject IKundenService KundenService
@inject IProjektService ProjektService
@inject IVorgangService VorgangService
@inject ITeamService TeamService
@inject IMitarbeiterService MitarbeiterService
@inject IBuchungsService BuchungsService
@inject IAnwesenheitService AnwesenheitService
@inject IDokumentService DokumentService
@inject IJSRuntime JsRuntime
@using ItreeNet.Data.Extensions
@inject ISnackbar Snackbar
@layout Layout

<style>
    label {
        width: 100px;
    }

    .mud-picker-inline-paper {
        min-width: 320px !important;
    }
</style>

<div style="margin-right: 10px;">
    <h3 class="text-gray-800">Reports</h3>
</div>

@if (_isLoading)
{
    <ItreeSpinner />
}
else
{
    <div class="box bg-@Benutzer!.ThemeMode.ToString()!.ToLower() shadow mt2" style="overflow: visible;">
        <div class="text-gray-800">Abrechnung</div>
        <hr class="mt-1" />
        <div class="d-flex gap-3 align-items-end">
            <div style="width:150px;">
                <label>Datum</label>
                <MudDatePicker @bind-Date="@_abrechnungsDatum" Editable="true" Margin="Margin.Dense" />
            </div>
            <div class="d-flex gap-2">
                @if (_isLoadingArbeitsrapport)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="true" Size="Size.Small">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        Arbeitsrapport erstellen
                    </MudButton>
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Button" StartIcon="@Icons.Material.Filled.Description" OnClick="@ErstelleArbeitsrapporteAsync" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Disabled="@_isLoadingAbrechnung">
                        Arbeitsrapport erstellen
                    </MudButton>
                }
                @if (_isLoadingAbrechnung)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="true" Size="Size.Small">
                        <MudProgressCircular Indeterminate="true" Color="Color.Success" Size="Size.Small" />
                        Abrechnung durchgeführt
                    </MudButton>
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Button" StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="@FuehreAbrechnungDurchAsync" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Disabled="@_isLoadingArbeitsrapport">
                        Abrechnung durchgeführt
                    </MudButton>
                }
            </div>
        </div>
    </div>

    <div class="box bg-@Benutzer!.ThemeMode.ToString()!.ToLower() shadow mt-2">
        <div class="text-gray-800">Projektübersicht erstellen</div>
        <hr class="mt-1" />
        <div class="d-flex justify-content-between">
            <div>
                <label for="dropdownlist_jahr">Jahr</label>
                <MudSelect @bind-Value="@_selectedJahr" Style="width:200px;" Margin="Margin.Dense">
                    @if (_jahr != null)
                    {
                        @foreach (var item in _jahr)
                        {
                            <MudSelectItem Value="item">@item</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div>
                <label for="dropdownlist_monatvon">Monat von</label>
                <MudSelect @bind-Value="@_selectedMonatVon" Style="width:200px;" Margin="Margin.Dense">
                    @if (_monatVon != null)
                    {
                        @foreach (var item in _monatVon)
                        {
                            <MudSelectItem Value="item">@item</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div>
                <label for="dropdownlist_monatbis">Monat bis</label>
                <MudSelect @bind-Value="@_selectedMonatBis" Style="width:200px;" Margin="Margin.Dense">
                    @if (_monatBis != null)
                    {
                        @foreach (var item in _monatBis)
                        {
                            <MudSelectItem Value="item">@item</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div>
                <label for="dropdownlist_kunde">Kunde</label>
                <MudSelect T="Guid?" Value="@_selectedKundeAusw" ValueChanged="@OnKundeAuswChangedAsync" Style="width:300px;" Margin="Margin.Dense">
                    @if (_kundenAusw != null)
                    {
                        @foreach (var item in _kundenAusw.OrderBy(k => k.Kundenname))
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Kundenname</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-2">
            <div>
                <label for="dropdownlist_alleprojekt">Projekt</label>
                <MudSelect @bind-Value="@_selectedProjektAusw" Style="width:500px;" Margin="Margin.Dense">
                    @if (_projekteAusw != null)
                    {
                        @foreach (var item in _projekteAusw.OrderBy(p => p.Nummer).ThenBy(p => p.Bezeichnung))
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Bezeichnung</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div>
                <label for="checkbox_projectstatus" style="width: 150px;">Aktive Projekte</label>
                <MudCheckBox @bind-Value="_onlyActiveProjects" T="bool" />
            </div>
            <div class="d-flex justify-content-end align-self-end" style="width: auto">
                @if (_isLoadingDownload)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="true" OnClick="@ErstelleProjektuebersichtAsync" Size="Size.Small">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        Projektübersicht erstellen
                    </MudButton>
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Button" StartIcon="@Icons.Material.Filled.Settings" OnClick="@ErstelleProjektuebersichtAsync" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Disabled="@(_selectedProjektAusw == null)">
                        Projektübersicht erstellen
                    </MudButton>
                }
            </div>
        </div>
    </div>

    <div class="box @theme shadow mt-2">
        <div>
            <div class="text-gray-800">Suche</div>
        </div>
        <hr class="mt-1" />
        <div class="d-flex justify-content-between">
            <div>
                <label for="dropdownlist_mitarbeiter">Mitarbeiter</label>
                <MudSelect @bind-Value="@_selectedMitarbeiter" Style="width:300px;" Margin="Margin.Dense">
                    <MudSelectItem Value="@((Guid?)null)">— Auswählen —</MudSelectItem>
                    @if (_mitarbeiter != null)
                    {
                        @foreach (var item in _mitarbeiter)
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Fullname</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div>
                <label for="dropdownlist_team">Team</label>
                <MudSelect @bind-Value="@_selectedTeam" Style="width:300px;" Margin="Margin.Dense">
                    <MudSelectItem Value="@((Guid?)null)">— Auswählen —</MudSelectItem>
                    @if (_teams != null)
                    {
                        @foreach (var item in _teams)
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Bezeichnung</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div style="width:150px;">
                <label for="fromDate">Datum ab</label>
                <MudDatePicker @bind-Date="@_fromDate" Editable="true" Margin="Margin.Dense" />
            </div>
            <div style="width:150px;">
                <label for="toDate">Datum bis</label>
                <MudDatePicker @bind-Date="@_toDate" Editable="true" Margin="Margin.Dense" />
            </div>
        </div>
        <div class="d-flex justify-content-between mt-2">
            <div>
                <label for="dropdownlist_kunde">Kunde</label>
                <MudSelect T="Guid?" Value="@_selectedKunde" ValueChanged="@OnKundeChangedAsync" Style="width:300px;" Margin="Margin.Dense">
                    @if (_kunden != null)
                    {
                        @foreach (var item in _kunden)
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Kundenname</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div>
                <label for="dropdownlist_projekt">Projekt</label>
                <MudSelect T="Guid?" Value="@_selectedProjekt" ValueChanged="@OnProjektChangedAsync" Style="width:300px;" Margin="Margin.Dense">
                    @if (_projekte != null)
                    {
                        @foreach (var item in _projekte)
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Bezeichnung</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div>
                <label for="dropdownlist_aktivitaet">Aktivität</label>
                <MudSelect @bind-Value="@_selectedAktivitaet" Style="width:300px;" Margin="Margin.Dense">
                    @if (_aktivitaeten != null)
                    {
                        @foreach (var item in _aktivitaeten)
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Bezeichnung</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div class="d-flex justify-content-end align-self-end" style="width: auto">
                @if (_isLoadingBookings)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="true" OnClick="@SucheBuchungenAsync" Size="Size.Small">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        Suchen
                    </MudButton>
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Button" StartIcon="@Icons.Material.Filled.Search" OnClick="@SucheBuchungenAsync" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                        Suchen
                    </MudButton>
                }
            </div>
        </div>
    </div>

    @if (_isLoading || _buchungen != null)
    {
        <div class="box bg-@Benutzer!.ThemeMode.ToString()!.ToLower() shadow mt-2">
            <div>
                <div class="text-gray-800">Buchungen</div>
            </div>
            <hr class="mt-1" />
            @if (_isLoadingBookings)
            {
                <ItreeSpinner />
            }
            else if (!_isLoadingBookings && _buchungen != null)
            {
                <MudDataGrid T="Buchung" Items="_buchungen" Dense="true" Hover="true" Bordered="true" Striped="true"
                             SortMode="SortMode.Multiple" Groupable="true"
                             FilterMode="DataGridFilterMode.ColumnFilterRow">
                    <ToolBarContent>
                        <MudButton OnClick="ExportBuchungenExcelAsync" StartIcon="@Icons.Material.Filled.TableChart" Variant="Variant.Filled" Color="Color.Primary">Export to Excel</MudButton>
                    </ToolBarContent>
                    <Columns>
                        <PropertyColumn Property="x => x.Datum" Title="Datum" Format="dd.MM.yyyy" Groupable="true" />
                        <PropertyColumn Property="x => x.KundenName" Title="Kunde" Groupable="true" />
                        <PropertyColumn Property="x => x.ProjektName" Title="Projekt" Groupable="true" />
                        <PropertyColumn Property="x => x.Vorgang!.Bezeichnung" Title="Aktivität" Groupable="true" />
                        <PropertyColumn Property="x => x.Mitarbeiter!.Fullname" Title="Mitarbeiter" Groupable="true" />
                        <TemplateColumn Title="Zeit">
                            <CellTemplate Context="item">
                                @item.Item.Zeit.FormatMinutenAlsZeit()h
                            </CellTemplate>
                            <FooterTemplate>
                                @_buchungenZeitSum.FormatMinutenAlsZeit()h
                            </FooterTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.Buchungstext" Title="Buchungstext" />
                    </Columns>
                </MudDataGrid>
            }
        </div>
    }

    <div class="box @theme shadow mt-2">
        <div class="text-gray-800">Anwesenheitsauswertung</div>
        <hr class="mt-1" />
        <div class="d-flex gap-3">
            <div>
                <label>Mitarbeiter</label>
                <MudSelect @bind-Value="@_anwSelectedMitarbeiter" Style="width:300px;" Margin="Margin.Dense">
                    <MudSelectItem Value="@((Guid?)null)">— Alle —</MudSelectItem>
                    @if (_mitarbeiter != null)
                    {
                        @foreach (var item in _mitarbeiter)
                        {
                            <MudSelectItem Value="@((Guid?)item.Id)">@item.Fullname</MudSelectItem>
                        }
                    }
                </MudSelect>
            </div>
            <div style="width:200px;">
                <label>Datum ab</label>
                <MudDatePicker @bind-Date="@_anwFromDate" Editable="true" Margin="Margin.Dense" />
            </div>
            <div style="width:200px;">
                <label>Datum bis</label>
                <MudDatePicker @bind-Date="@_anwToDate" Editable="true" Margin="Margin.Dense" />
            </div>
            <div class="d-flex align-self-end">
                @if (_isLoadingAnwesenheit)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="true" Size="Size.Small">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        Suchen
                    </MudButton>
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Button" StartIcon="@Icons.Material.Filled.Search" OnClick="@SucheAnwesenheitenAsync" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                        Suchen
                    </MudButton>
                }
            </div>
        </div>
    </div>

    @if (_anwesenheiten != null)
    {
        <div class="box bg-@Benutzer!.ThemeMode.ToString()!.ToLower() shadow mt-2">
            <div class="text-gray-800">Anwesenheiten</div>
            <hr class="mt-1" />
            @if (_isLoadingAnwesenheit)
            {
                <ItreeSpinner />
            }
            else
            {
                <MudDataGrid T="Anwesenheit" Items="_anwesenheiten" Dense="true" Hover="true" Bordered="true" Striped="true"
                             SortMode="SortMode.Multiple" Groupable="true"
                             FilterMode="DataGridFilterMode.ColumnFilterRow">
                    <ToolBarContent>
                        <MudButton OnClick="ExportAnwesenheitenExcelAsync" StartIcon="@Icons.Material.Filled.TableChart" Variant="Variant.Filled" Color="Color.Primary">Export to Excel</MudButton>
                    </ToolBarContent>
                    <Columns>
                        <PropertyColumn Property="x => x.Datum" Title="Datum" Format="dd.MM.yyyy" Groupable="true" />
                        <PropertyColumn Property="x => x.Mitarbeiter!.Fullname" Title="Mitarbeiter" Groupable="true" />
                        <PropertyColumn Property="x => x.Typ" Title="Typ" Groupable="true" />
                        <TemplateColumn Title="Stunden">
                            <CellTemplate Context="item">
                                @item.Item.Zeit?.ToString("N2")
                            </CellTemplate>
                            <FooterTemplate>
                                @_anwesenheitenZeitSum.ToString("N2") h
                            </FooterTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Von">
                            <CellTemplate Context="item">
                                @item.Item.ZeitVon?.ToString("HH:mm")
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Bis">
                            <CellTemplate Context="item">
                                @item.Item.ZeitBis?.ToString("HH:mm")
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.Notiz" Title="Notiz" />
                    </Columns>
                </MudDataGrid>

                @if (_anwesenheitenZusammenfassung.Count > 0)
                {
                    <div class="mt-3">
                        <div class="text-gray-800">Zusammenfassung pro Mitarbeiter</div>
                        <hr class="mt-1" />
                        <table class="table table-sm table-striped @(_tableTheme)">
                            <thead>
                                <tr>
                                    <th>Mitarbeiter</th>
                                    <th>Anwesenheit</th>
                                    <th>Ferien</th>
                                    <th>Gleitzeit</th>
                                    <th>Krank</th>
                                    <th>Abwesenheit</th>
                                    <th>Gesamt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var z in _anwesenheitenZusammenfassung)
                                {
                                    <tr>
                                        <td>@z.Mitarbeiter</td>
                                        <td>@z.Anwesenheit.ToString("N2") h</td>
                                        <td>@z.Ferien.ToString("N2") h</td>
                                        <td>@z.Gleitzeit.ToString("N2") h</td>
                                        <td>@z.Krank.ToString("N2") h</td>
                                        <td>@z.Abwesenheit.ToString("N2") h</td>
                                        <td><strong>@z.Gesamt.ToString("N2") h</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    }
}

@code {
    [CascadingParameter]
    public Benutzer? Benutzer { get; set; }

    public Guid MitarbeiterId { get; set; }

    private bool _isLoading = true;
    private bool _isLoadingBookings;
    private bool _isLoadingDownload;
    private bool _isLoadingArbeitsrapport;
    private bool _isLoadingAbrechnung;
    private bool _isLoadingAnwesenheit;

    private DateTime? _abrechnungsDatum;

    private List<MitarbeiterModel>? _mitarbeiter;
    private List<Team>? _teams;
    private List<Kunde>? _kunden;
    private List<Projekt>? _projekte;
    private List<Vorgang>? _aktivitaeten;
    private List<Buchung>? _buchungen;
    private int _buchungenZeitSum;

    private List<Projekt>? _projekteAusw;
    private Guid? _selectedProjektAusw;
    private List<Kunde>? _kundenAusw;
    private Guid? _selectedKundeAusw;

    private List<int>? _jahr;
    private int _selectedJahr = DateTime.Now.Year;
    private List<int>? _monatVon;
    private int _selectedMonatVon = DateTime.Now.Month;
    private List<int>? _monatBis;
    private int _selectedMonatBis = DateTime.Now.Month;
    private bool _onlyActiveProjects = true;

    private Guid? _selectedMitarbeiter;
    private Guid? _selectedTeam;
    private Guid? _selectedKunde;
    private Guid? _selectedProjekt;
    private Guid? _selectedAktivitaet;

    // MudDatePicker uses DateTime? instead of DateOnly?
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private DateOnly? _from => _fromDate.HasValue ? DateOnly.FromDateTime(_fromDate.Value) : null;
    private DateOnly? _to => _toDate.HasValue ? DateOnly.FromDateTime(_toDate.Value) : null;

    // Anwesenheitsauswertung
    private Guid? _anwSelectedMitarbeiter;
    private DateTime? _anwFromDate = DateTime.Today.Day <= 5
        ? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-1)
        : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _anwToDate = DateTime.Today.Day <= 5
        ? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddDays(-1)
        : DateTime.Today;
    private List<Anwesenheit>? _anwesenheiten;
    private decimal _anwesenheitenZeitSum;
    private List<AnwesenheitZusammenfassung> _anwesenheitenZusammenfassung = new();

    private string theme = string.Empty;
    private string _tableTheme = "table-light";

    /// <summary>
    /// Initialisiert die Seite: Lädt Stammdaten (Mitarbeiter, Kunden, Teams) und setzt Standardwerte.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (Benutzer == null || Benutzer.MitarbeiterId == null)
            throw new Exception("Kein Benutzer gefunden");

        theme = $"bg-{Benutzer!.ThemeMode.ToString()!.ToLower()}";
        _tableTheme = $"table-{Benutzer.ThemeMode.ToString()!.ToLower()}";
        MitarbeiterId = (Guid)Benutzer.MitarbeiterId;

        var heute = DateTime.Today;
        _abrechnungsDatum = new DateTime(heute.Year, heute.Month, 1).AddDays(-1);

        _mitarbeiter = await MitarbeiterService.GetAllActiveAsync();
        _kunden = await KundenService.GetAllActiveAsync();
        _teams = await TeamService.GetAllAsync();
        _isLoading = false;

        _jahr = new List<int>();
        for (var jahr = DateTime.Today.Year; jahr > 2007; jahr--)
        {
            _jahr.Add(jahr);
        }
        _monatVon = new List<int>();
        _monatBis = new List<int>();
        for (var monat = 1; monat < 13; monat++)
        {
            _monatVon.Add(monat);
            _monatBis.Add(monat);
        }
        _kundenAusw = await KundenService.GetAllActiveAsync();
        _projekteAusw = new List<Projekt>();
    }

    /// <summary>
    /// Sucht Buchungen anhand der gewählten Filterkriterien (Mitarbeiter, Team, Kunde, Projekt, Aktivität, Zeitraum).
    /// </summary>
    private async Task SucheBuchungenAsync()
    {
        _isLoadingBookings = true;
        _buchungen = await BuchungsService.SucheBuchungAsync(_selectedMitarbeiter, _selectedTeam, _selectedKunde, _selectedProjekt, _selectedAktivitaet, _from, _to);
        _buchungenZeitSum = _buchungen?.Sum(b => b.Zeit ?? 0) ?? 0;
        _isLoadingBookings = false;
    }

    /// <summary>
    /// Erstellt eine Projektübersicht als Dokument für den gewählten Zeitraum und das gewählte Projekt.
    /// </summary>
    private async Task ErstelleProjektuebersichtAsync()
    {
        if (!_selectedProjektAusw.HasValue)
            return;

        _isLoadingDownload = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var filePath = await DokumentService.CreateProjektUebersicht(_selectedJahr, _selectedMonatVon, _selectedMonatBis, _selectedProjektAusw.Value);
            await DownloadFileAsync(filePath);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }

        _isLoadingDownload = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Erstellt Arbeitsrapporte für alle offenen Buchungen bis zum gewählten Abrechnungsdatum.
    /// </summary>
    private async Task ErstelleArbeitsrapporteAsync()
    {
        if (_abrechnungsDatum == null)
            return;

        _isLoadingArbeitsrapport = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var bis = DateOnly.FromDateTime(_abrechnungsDatum.Value);
            var filePath = await DokumentService.CreateArbeitsrapporteOffeneBuchungen(bis);
            await DownloadFileAsync(filePath);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }

        _isLoadingArbeitsrapport = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Markiert alle offenen Buchungen als abgerechnet.
    /// </summary>
    private async Task FuehreAbrechnungDurchAsync()
    {
        _isLoadingAbrechnung = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await BuchungsService.SetAbgerechnetAsync();
            Snackbar.Add("Abrechnung erfolgreich durchgeführt", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }

        _isLoadingAbrechnung = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Callback bei Kundenauswahl im Suchbereich. Lädt zugehörige Projekte nach.
    /// </summary>
    private async Task OnKundeChangedAsync(Guid? value)
    {
        _selectedKunde = value;
        _projekte = await ProjektService.ProjectsByCustomerIdAsync(_selectedKunde);
    }

    /// <summary>
    /// Callback bei Projektauswahl im Suchbereich. Lädt zugehörige Aktivitäten nach.
    /// </summary>
    private async Task OnProjektChangedAsync(Guid? value)
    {
        _selectedProjekt = value;
        _aktivitaeten = await VorgangService.GetAllProjecIdAsync(_selectedProjekt);
    }

    /// <summary>
    /// Callback bei Kundenauswahl im Projektübersicht-Bereich. Lädt zugehörige Projekte nach.
    /// </summary>
    private async Task OnKundeAuswChangedAsync(Guid? value)
    {
        _selectedKundeAusw = value;

        if (_selectedKundeAusw == null)
        {
            _selectedProjektAusw = null;
            _projekteAusw = new List<Projekt>();
        }
        else
        {
            var status = _onlyActiveProjects ? EnumStatus.Aktiv : EnumStatus.Inaktiv;
            _projekteAusw = await ProjektService.ProjectsByCustomerIdAsync(_selectedKundeAusw, status);
        }
    }

    #region Anwesenheitsauswertung

    /// <summary>
    /// Sucht Anwesenheitseinträge anhand Mitarbeiter und Zeitraum und berechnet die Zusammenfassung.
    /// </summary>
    private async Task SucheAnwesenheitenAsync()
    {
        _isLoadingAnwesenheit = true;
        await InvokeAsync(StateHasChanged);

        var von = _anwFromDate.HasValue ? DateOnly.FromDateTime(_anwFromDate.Value) : (DateOnly?)null;
        var bis = _anwToDate.HasValue ? DateOnly.FromDateTime(_anwToDate.Value) : (DateOnly?)null;

        _anwesenheiten = await AnwesenheitService.SucheAnwesenheitAsync(_anwSelectedMitarbeiter, von, bis);
        _anwesenheitenZeitSum = _anwesenheiten?.Sum(a => a.Zeit ?? 0) ?? 0;

        BerechneAnwesenheitZusammenfassung();

        _isLoadingAnwesenheit = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Gruppiert die geladenen Anwesenheiten pro Mitarbeiter und berechnet Stundensummen je Typ.
    /// </summary>
    private void BerechneAnwesenheitZusammenfassung()
    {
        if (_anwesenheiten == null || _anwesenheiten.Count == 0)
        {
            _anwesenheitenZusammenfassung = new();
            return;
        }

        _anwesenheitenZusammenfassung = _anwesenheiten
            .GroupBy(a => new { a.MitarbeiterId, Name = a.Mitarbeiter?.Fullname ?? "Unbekannt" })
            .Select(g => new AnwesenheitZusammenfassung
            {
                Mitarbeiter = g.Key.Name,
                Anwesenheit = g.Where(a => a.Typ == EnumAnwesenheitTyp.Anwesenheit).Sum(a => a.Zeit ?? 0),
                Ferien = g.Where(a => a.Typ == EnumAnwesenheitTyp.Ferien).Sum(a => a.Zeit ?? 0),
                Gleitzeit = g.Where(a => a.Typ == EnumAnwesenheitTyp.Gleitzeit).Sum(a => a.Zeit ?? 0),
                Krank = g.Where(a => a.Typ == EnumAnwesenheitTyp.Krank).Sum(a => a.Zeit ?? 0),
                Abwesenheit = g.Where(a => a.Typ == EnumAnwesenheitTyp.Abwesenheit).Sum(a => a.Zeit ?? 0)
            })
            .OrderBy(z => z.Mitarbeiter)
            .ToList();
    }

    #endregion
}
